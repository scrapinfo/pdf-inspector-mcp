{
  "name": "pdf-inspector-mcp",
  "version": "1.0.0",
  "description": "A zero-config MCP server to inspect local PDF files using standard TypeScript libraries.",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "pdf-inspector-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": [
    "mcp",
    "pdf",
    "ocr",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "canvas": "^3.2.3",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^6.0.227",
    "tesseract.js": "^7.0.0",
    "zod": "^3.25.31"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
